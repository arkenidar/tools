{
  "version": "0.2.0",
  "compounds": [
    {
      "name": "[compound] dev-server-debug",
      "configurations": ["Listen for Xdebug", "dev-server (xdebug)"],
      "stopAll": true
    }
  ],
  "configurations": [
    {
      "name": "dev-server",
      "type": "node-terminal",
      "request": "launch",
      "command": "php -S localhost:8000 -t \"${workspaceFolder}\"",
      "cwd": "${workspaceFolder}",
      "serverReadyAction": {
        "pattern": "Development Server \\(http://localhost:([0-9]+)\\) started",
        "uriFormat": "http://localhost:%s/",
        "action": "openExternally"
      }
    },
    {
      "name": "Listen for Xdebug",
      "type": "php",
      "request": "launch",
      "port": 9003
    },
    {
      "name": "dev-server (xdebug)",
      "type": "node-terminal",
      "request": "launch",
      "command": "php -d xdebug.mode=debug -d xdebug.start_with_request=yes -d xdebug.client_port=9003 -S localhost:8000 -t \"${workspaceFolder}\"",
      "cwd": "${workspaceFolder}",
      "serverReadyAction": {
        "pattern": "Development Server \\(http://localhost:([0-9]+)\\) started",
        "uriFormat": "http://localhost:%s/",
        "action": "openExternally"
      }
    }
  ]
}
